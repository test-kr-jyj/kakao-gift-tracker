      "brand_id": "${brandId}",
      "brand_name": "${brandName}",
      "adtrack_service_origin": "gift",
      "seller_id": "${sellerId}",
      "seller_name": "${sellerName}",
      "api_result": "${apiResult}",
      "id_service": "gift"
